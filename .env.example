# SkyMarket - Telegram Mini App Marketplace Configuration Example

# MongoDB Database Connection String
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/skymarket?retryWrites=true&w=majority

# JWT Token Secret for Secure Seller Account Sockets Auth (Optional)
JWT_SECRET=super_secret_jwt_hmac_sha256_key_skymarket_2026

# Telegram Bot Token (for WebApp authentication and secure validation)
BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ_12345678

# Nodejs running environment
NODE_ENV=development
