# ============================================
#   MARKETPLACE ENV — انسخ هذا الملف لـ .env
#   لا تضع بيانات حقيقية هنا أبداً!
# ============================================

NODE_ENV=production
PORT=3000

# قاعدة البيانات
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/marketplace

# بوت تيليغرام (من @BotFather)
BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff1234567890

# ID تيليغرام الخاص بالمالك
OWNER_ID=123456789

# رابط التطبيق على Railway/Render
APP_URL=https://your-app.up.railway.app
WEBHOOK_URL=https://your-app.up.railway.app

# مفاتيح التشفير — يجب أن تكون عشوائية وقوية
# ولّدها بـ: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=GENERATE_32_RANDOM_BYTES_HEX_HERE
ENCRYPTION_SALT=GENERATE_ANOTHER_32_RANDOM_BYTES_HEX_HERE

# جلسة التطوير فقط (لا تشارك هذا)
DEV_SECRET=change_this_in_dev

# Cloudinary لرفع الصور
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# إعدادات العملة (اختياري)
DEFAULT_CRYSTAL_PRICE_USD=0.01
DEFAULT_COMMISSION_PERCENT=5

# Redis لـ BullMQ (اختياري — يعمل بدونه بـ setInterval)
REDIS_URL=redis://localhost:6379
